<UserControl x:Class="Kexplorer.UI.TextViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,2"
                    Background="{DynamicResource ToolbarBackgroundBrush}">
            <Button x:Name="OpenButton" Content="📂 Open" Width="70" Height="24"
                    Margin="2,0" Click="OpenButton_Click" ToolTip="Open a file (Ctrl+O)"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Button x:Name="SaveButton" Content="💾 Save" Width="70" Height="24"
                    Margin="2,0" Click="SaveButton_Click" ToolTip="Save (Ctrl+S)" IsEnabled="False"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Button x:Name="SaveAsButton" Content="💾 Save As" Width="80" Height="24"
                    Margin="2,0" Click="SaveAsButton_Click" ToolTip="Save As (Ctrl+Shift+S)" IsEnabled="False"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Button x:Name="RefreshButton" Content="⟳ Refresh" Width="80" Height="24"
                    Margin="2,0" Click="RefreshButton_Click" ToolTip="Reload file from disk"
                    IsEnabled="False"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Separator Width="8" Visibility="Hidden" />
            <CheckBox x:Name="WordWrapCheckBox" Content="Word Wrap" VerticalAlignment="Center"
                      IsChecked="True" Checked="WordWrapChanged" Unchecked="WordWrapChanged" />
            <Separator Width="8" Visibility="Hidden" />
            <CheckBox x:Name="EditModeCheckBox" Content="Edit" VerticalAlignment="Center"
                      IsChecked="False" Checked="EditModeChanged" Unchecked="EditModeChanged"
                      ToolTip="Toggle editing (read-only by default)" />
            <Separator Width="12" Visibility="Hidden" />
            <TextBlock x:Name="FilePathLabel" Text="(no file loaded)" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                       TextTrimming="CharacterEllipsis" MaxWidth="600" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </StackPanel>

        <!-- Find/Replace Bar -->
        <Border Grid.Row="1" x:Name="FindBar" Visibility="Collapsed"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Find row -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="Find:" VerticalAlignment="Center" Width="55" Margin="0,0,4,0" />
                    <TextBox x:Name="FindTextBox" Width="250" Height="22"
                             VerticalContentAlignment="Center" FontSize="12"
                             KeyDown="FindTextBox_KeyDown" />
                    <Button Content="▼ Next" Width="60" Height="22" Margin="4,0,0,0"
                            Click="FindNext_Click" ToolTip="Find Next (F3)"
                            Style="{DynamicResource ToolbarButtonStyle}" />
                    <Button Content="▲ Prev" Width="60" Height="22" Margin="2,0,0,0"
                            Click="FindPrev_Click" ToolTip="Find Previous (Shift+F3)"
                            Style="{DynamicResource ToolbarButtonStyle}" />
                    <Separator Width="8" Visibility="Hidden" />
                    <CheckBox x:Name="MatchCaseCheckBox" Content="Match case"
                              VerticalAlignment="Center" />
                    <Separator Width="8" Visibility="Hidden" />
                    <TextBlock x:Name="FindStatusLabel" Text="" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" />
                    <Separator Width="12" Visibility="Hidden" />
                    <Button Content="✕" Width="22" Height="22" Click="CloseFindBar_Click"
                            ToolTip="Close (Escape)"
                            Style="{DynamicResource ToolbarButtonStyle}" />
                </StackPanel>

                <!-- Replace row -->
                <StackPanel Grid.Row="1" x:Name="ReplaceRow" Orientation="Horizontal"
                            Visibility="Collapsed" Margin="0,3,0,0">
                    <TextBlock Text="Replace:" VerticalAlignment="Center" Width="55" Margin="0,0,4,0" />
                    <TextBox x:Name="ReplaceTextBox" Width="250" Height="22"
                             VerticalContentAlignment="Center" FontSize="12"
                             KeyDown="ReplaceTextBox_KeyDown" />
                    <Button Content="Replace" Width="60" Height="22" Margin="4,0,0,0"
                            Click="ReplaceOne_Click" ToolTip="Replace current match"
                            Style="{DynamicResource ToolbarButtonStyle}" />
                    <Button Content="All" Width="40" Height="22" Margin="2,0,0,0"
                            Click="ReplaceAll_Click" ToolTip="Replace all matches"
                            Style="{DynamicResource ToolbarButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Text Content with Line Numbers -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Line Number Gutter -->
            <Canvas Grid.Column="0" x:Name="LineNumberCanvas"
                    Width="50" ClipToBounds="True"
                    Background="{DynamicResource ToolbarBackgroundBrush}" />

            <!-- Text Editor -->
            <TextBox Grid.Column="1" x:Name="ContentTextBox"
                     AcceptsReturn="True" AcceptsTab="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     BorderThickness="0"
                     SelectionChanged="ContentTextBox_SelectionChanged"
                     TextChanged="ContentTextBox_TextChanged"
                     ScrollViewer.ScrollChanged="ContentTextBox_ScrollChanged"
                     Background="{DynamicResource SecondaryBackgroundBrush}"
                     Foreground="{DynamicResource PrimaryForegroundBrush}"
                     CaretBrush="{DynamicResource AccentBrush}"
                     SelectionBrush="{DynamicResource SelectionBrush}">
                <TextBox.InputBindings>
                    <KeyBinding Key="S" Modifiers="Ctrl" Command="ApplicationCommands.NotACommand" />
                    <KeyBinding Key="O" Modifiers="Ctrl" Command="ApplicationCommands.NotACommand" />
                </TextBox.InputBindings>
            </TextBox>
        </Grid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="4,2"
                    Background="{DynamicResource ToolbarBackgroundBrush}">
            <TextBlock x:Name="PositionLabel" Text="Ln 1, Col 1" VerticalAlignment="Center"
                       Margin="4,0" Width="120" />
            <Separator Width="8" Visibility="Hidden" />
            <TextBlock x:Name="EncodingLabel" Text="" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" />
            <Separator Width="8" Visibility="Hidden" />
            <TextBlock x:Name="FileSizeLabel" Text="" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryForegroundBrush}" />
            <Separator Width="8" Visibility="Hidden" />
            <TextBlock x:Name="ModifiedLabel" Text="" VerticalAlignment="Center"
                       Foreground="OrangeRed" />
        </StackPanel>
    </Grid>
</UserControl>

<Window x:Class="Kexplorer.UI.MediaViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Viewer" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Image display -->
        <Image x:Name="ImageDisplay" Grid.Row="0"
               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />

        <!-- Video display -->
        <MediaElement x:Name="VideoDisplay" Grid.Row="0"
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Stretch="Uniform" Visibility="Collapsed"
                      MediaEnded="VideoDisplay_MediaEnded" />

        <!-- Navigation bar -->
        <Border Grid.Row="1" Background="#222" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton" Grid.Column="0" Content="◀ Previous"
                        Padding="12,6" Margin="4" MinWidth="100"
                        Click="PrevButton_Click" />

                <TextBlock x:Name="FileInfoText" Grid.Column="2"
                           Foreground="White" VerticalAlignment="Center"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FontSize="13" />

                <Button x:Name="NextButton" Grid.Column="4" Content="Next ▶"
                        Padding="12,6" Margin="4" MinWidth="100"
                        Click="NextButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>

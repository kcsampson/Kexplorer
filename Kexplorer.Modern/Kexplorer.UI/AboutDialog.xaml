<Window x:Class="Kexplorer.UI.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Kimbonics"
        Height="380" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource PrimaryBackgroundBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: Theme list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Theme"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForegroundBrush}"
                       Margin="0,0,0,8" />
            <ListBox x:Name="ThemeList"
                     SelectionChanged="ThemeList_SelectionChanged"
                     Background="{DynamicResource SecondaryBackgroundBrush}"
                     Foreground="{DynamicResource PrimaryForegroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1" />
        </DockPanel>

        <!-- Right panel: Splash image + branding -->
        <DockPanel Grid.Column="1">
            <!-- Bottom: branding + close button -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <TextBlock Text="Made by Kimbonics"
                           FontSize="15" FontWeight="Bold" FontStyle="Italic"
                           Foreground="{DynamicResource PrimaryForegroundBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                <Button Content="Close" Width="80" Height="28"
                        HorizontalAlignment="Center"
                        IsCancel="True"
                        Click="Close_Click" />
            </StackPanel>

            <!-- Center: splash image -->
            <Border CornerRadius="6" Margin="0,0,0,0"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Image x:Name="SplashImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="8" />
            </Border>
        </DockPanel>
    </Grid>
</Window>

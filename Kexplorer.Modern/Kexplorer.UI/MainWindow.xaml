<Window x:Class="Kexplorer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kexplorer.UI"
        Title="Kimbonics" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- Template for closable/renamable tab headers -->
        <DataTemplate x:Key="ClosableTabHeader">
            <StackPanel Orientation="Horizontal">
                <!-- Display label: double-click to rename -->
                <TextBlock x:Name="TabLabel" Text="{Binding}" 
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="TabLabel_MouseLeftButtonDown" />
                <!-- Edit box: shown during rename, hidden by default -->
                <TextBox x:Name="TabEditBox"
                         Visibility="Collapsed" MinWidth="60"
                         VerticalAlignment="Center"
                         KeyDown="TabEditBox_KeyDown"
                         LostFocus="TabEditBox_LostFocus" />
                <!-- Close button -->
                <Button Content="×" FontSize="10" 
                        Padding="4,0" Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        BorderThickness="0" Background="Transparent"
                        ToolTip="Close tab"
                        Click="CloseTab_Click" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <!-- Tab control fills remaining space; gear overlays the tab strip -->
        <Grid>
            <TabControl x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged">
                <!-- Permanent "+" tab for adding new tabs -->
                <TabItem x:Name="AddTabButton" Header="+" ToolTip="Add new tab"
                         FontWeight="Bold" Padding="6,2" />
            </TabControl>
            <!-- Settings gear overlaid top-right, on the tab strip row only -->
            <Button x:Name="SettingsGearButton"
                    Content="⚙" FontSize="14" Width="26" Height="26"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,0,6,0"
                    BorderThickness="0" Background="Transparent" Cursor="Hand"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    ToolTip="Settings" Click="SettingsGear_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="SettingsContextMenu">
                        <MenuItem Header="_Theme" x:Name="ThemeMenu" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>
    </DockPanel>
</Window>

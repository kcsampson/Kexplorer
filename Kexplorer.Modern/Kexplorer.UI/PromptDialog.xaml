<Window x:Class="Kexplorer.UI.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource PrimaryBackgroundBrush}">
    <StackPanel Margin="15">
        <TextBlock x:Name="MessageText" Text="Enter value:" TextWrapping="Wrap" Margin="0,0,0,8"
                   Foreground="{DynamicResource PrimaryForegroundBrush}" />
        <TextBox x:Name="InputBox" Margin="0,0,0,12"
                 Background="{DynamicResource SecondaryBackgroundBrush}"
                 Foreground="{DynamicResource PrimaryForegroundBrush}"
                 CaretBrush="{DynamicResource PrimaryForegroundBrush}"
                 BorderBrush="{DynamicResource ThemeBorderBrush}" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Height="26" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Button Content="Cancel" Width="75" Height="26" IsCancel="True"
                    Style="{DynamicResource ToolbarButtonStyle}" />
        </StackPanel>
    </StackPanel>
</Window>

<UserControl x:Class="Kexplorer.UI.HybridServicesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" MinHeight="100" />
            <RowDefinition Height="5" />
            <RowDefinition Height="140" MinHeight="60" />
        </Grid.RowDefinitions>

        <!-- Top Pane: Windows Services -->
        <DockPanel Grid.Row="0">
            <!-- Toolbar -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2" Background="{DynamicResource ToolbarBackgroundBrush}">
                <TextBlock Text="Windows Services" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{DynamicResource PrimaryForegroundBrush}" />
                <Button x:Name="ServiceMoveUpButton" Content="▲ Up" Width="60" Height="24"
                        Margin="2,0" Click="ServiceMoveUp_Click" ToolTip="Move selected row up"
                        IsEnabled="False" Style="{DynamicResource ToolbarButtonStyle}" />
                <Button x:Name="ServiceMoveDownButton" Content="▼ Down" Width="66" Height="24"
                        Margin="2,0" Click="ServiceMoveDown_Click" ToolTip="Move selected row down"
                        IsEnabled="False" Style="{DynamicResource ToolbarButtonStyle}" />
                <Button x:Name="ServiceRefreshButton" Content="↻ Refresh" Width="80" Height="24"
                        Margin="2,0" Click="ServiceRefresh_Click" ToolTip="Refresh service list"
                        Style="{DynamicResource ToolbarButtonStyle}" />
                <Button x:Name="ServiceAddByPatternButton" Content="➕ Add" Width="66" Height="24"
                        Margin="2,0" Click="ServiceAddByPattern_Click" ToolTip="Add services matching a regex pattern"
                        Style="{DynamicResource ToolbarButtonStyle}" />
            </StackPanel>
            <DataGrid x:Name="ServiceGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      CanUserSortColumns="True">
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="ServiceContextMenu" />
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="300" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="System Name" Binding="{Binding ServiceName}" Width="200" />
                    <DataGridTextColumn Header="Type" Binding="{Binding ServiceType}" Width="120" />
                    <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="120" />
                    <DataGridCheckBoxColumn Header="Can Stop" Binding="{Binding CanStop}" Width="70" />
                    <DataGridCheckBoxColumn Header="Can Pause" Binding="{Binding CanPauseAndContinue}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="{DynamicResource ThemeBorderBrush}" ResizeBehavior="PreviousAndNext" />

        <!-- Bottom Pane: Docker Containers -->
        <DockPanel Grid.Row="2">
            <!-- Toolbar -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2" Background="{DynamicResource ToolbarBackgroundBrush}">
                <TextBlock Text="Docker Containers" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"
                           Foreground="{DynamicResource PrimaryForegroundBrush}" />
                <TextBlock x:Name="DockerStatusText" Text="" Margin="0,0,12,0"
                           VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}" FontStyle="Italic" />
                <Button x:Name="DockerMoveUpButton" Content="▲ Up" Width="60" Height="24"
                        Margin="2,0" Click="DockerMoveUp_Click" ToolTip="Move selected row up"
                        IsEnabled="False" Style="{DynamicResource ToolbarButtonStyle}" />
                <Button x:Name="DockerMoveDownButton" Content="▼ Down" Width="66" Height="24"
                        Margin="2,0" Click="DockerMoveDown_Click" ToolTip="Move selected row down"
                        IsEnabled="False" Style="{DynamicResource ToolbarButtonStyle}" />
                <Button x:Name="DockerRefreshButton" Content="↻ Refresh" Width="80" Height="24"
                        Margin="2,0" Click="DockerRefresh_Click" ToolTip="Refresh container list"
                        Style="{DynamicResource ToolbarButtonStyle}" />
            </StackPanel>
            <DataGrid x:Name="DockerGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      CanUserSortColumns="True">
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="DockerContextMenu" />
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Image" Binding="{Binding Image}" Width="250" />
                    <DataGridTextColumn Header="Ports" Binding="{Binding Ports}" Width="200" />
                    <DataGridTextColumn Header="Network" Binding="{Binding Network}" Width="120" />
                    <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Info Splitter -->
        <GridSplitter Grid.Row="3" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="{DynamicResource ThemeBorderBrush}" ResizeBehavior="PreviousAndNext" />

        <!-- Info Panel: Dynamic Tab Strip -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
            <TabControl x:Name="DetailTabControl" TabStripPlacement="Top">
                <!-- Tabs are added/removed dynamically based on selection -->
            </TabControl>
        </Border>
    </Grid>
</UserControl>

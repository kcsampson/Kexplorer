<UserControl x:Class="Kexplorer.UI.HybridServicesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" MinHeight="100" />
            <RowDefinition Height="5" />
            <RowDefinition Height="140" MinHeight="60" />
        </Grid.RowDefinitions>

        <!-- Top Pane: Windows Services -->
        <DataGrid x:Name="ServiceGrid" Grid.Row="0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  CanUserSortColumns="True">
            <DataGrid.ContextMenu>
                <ContextMenu x:Name="ServiceContextMenu" />
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="300" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="System Name" Binding="{Binding ServiceName}" Width="200" />
                <DataGridTextColumn Header="Type" Binding="{Binding ServiceType}" Width="120" />
                <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="120" />
                <DataGridCheckBoxColumn Header="Can Stop" Binding="{Binding CanStop}" Width="70" />
                <DataGridCheckBoxColumn Header="Can Pause" Binding="{Binding CanPauseAndContinue}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Gray" ResizeBehavior="PreviousAndNext" />

        <!-- Bottom Pane: Docker Containers -->
        <DockPanel Grid.Row="2">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2">
                <TextBlock Text="Docker Containers" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="DockerStatusText" Text="" Margin="12,0,0,0"
                           VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic" />
            </StackPanel>
            <DataGrid x:Name="DockerGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      CanUserSortColumns="True">
                <DataGrid.ContextMenu>
                    <ContextMenu x:Name="DockerContextMenu" />
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                    <DataGridTextColumn Header="Image" Binding="{Binding Image}" Width="250" />
                    <DataGridTextColumn Header="Ports" Binding="{Binding Ports}" Width="200" />
                    <DataGridTextColumn Header="Network" Binding="{Binding Network}" Width="120" />
                    <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Info Splitter -->
        <GridSplitter Grid.Row="3" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Gray" ResizeBehavior="PreviousAndNext" />

        <!-- Info Panel: Dynamic Tab Strip -->
        <Border Grid.Row="4" BorderBrush="Gray" BorderThickness="0,1,0,0">
            <TabControl x:Name="DetailTabControl" TabStripPlacement="Top">
                <!-- Tabs are added/removed dynamically based on selection -->
            </TabControl>
        </Border>
    </Grid>
</UserControl>
